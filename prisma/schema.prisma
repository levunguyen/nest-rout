generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN_GENEALOGY
  EDITOR_GENEALOGY
  VIEWER_GENEALOGY
}

enum TreeRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  GATHERING
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ReactionType {
  LIKE
  HEART
}

enum MediaKind {
  IMAGE
  VIDEO
}

model User {
  id                 String                 @id @default(cuid())
  fullName           String
  email              String                 @unique
  passwordHash       String
  role               UserRole               @default(ADMIN_GENEALOGY)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  sessions           Session[]
  memberships        FamilyTreeMembership[]
  ownedFamilyTrees   FamilyTree[]           @relation("FamilyTreeOwner")
  sentInvitations    Invitation[]           @relation("InvitationSender")
  acceptedInvitations Invitation[]          @relation("InvitationAcceptor")
  members            FamilyMember[]         @relation("CreatedBy")
  events             Event[]
  newsPosts          NewsPost[]             @relation("NewsPostAuthor")
  newsComments       NewsComment[]          @relation("NewsCommentAuthor")
  mediaAssets        MediaAsset[]           @relation("MediaAssetUploader")
  eventComments      EventComment[]         @relation("EventCommentAuthor")
  eventReactions     EventReaction[]        @relation("EventReactionAuthor")
}

model Session {
  id                String      @id @default(cuid())
  tokenHash         String      @unique
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeFamilyTreeId String?
  activeFamilyTree  FamilyTree? @relation("ActiveTreeSessions", fields: [activeFamilyTreeId], references: [id], onDelete: SetNull)
  expiresAt         DateTime
  createdAt         DateTime    @default(now())
  lastUsedAt        DateTime    @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([activeFamilyTreeId])
}

model FamilyTree {
  id            String                 @id @default(cuid())
  name          String
  ownerId       String
  owner         User                   @relation("FamilyTreeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  memberships   FamilyTreeMembership[]
  invitations   Invitation[]
  familyMembers FamilyMember[]
  events        Event[]
  newsPosts     NewsPost[]
  newsComments  NewsComment[]
  mediaAssets   MediaAsset[]
  activeSessions Session[]             @relation("ActiveTreeSessions")
  eventComments EventComment[]
  eventReactions EventReaction[]
}

model FamilyTreeMembership {
  id           String     @id @default(cuid())
  userId       String
  familyTreeId String
  role         TreeRole   @default(VIEWER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)

  @@unique([userId, familyTreeId])
  @@index([familyTreeId])
}

model Invitation {
  id               String           @id @default(cuid())
  token            String           @unique
  familyTreeId     String
  email            String
  role             TreeRole         @default(VIEWER)
  status           InvitationStatus @default(PENDING)
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  familyTree       FamilyTree       @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  invitedBy        User             @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?            @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([familyTreeId, email, status])
}

model FamilyMember {
  id           String     @id @default(cuid())
  familyTreeId String
  fullName     String
  gender       Gender?
  birthYear    Int?
  deathYear    Int?
  address      String?
  city         String?
  country      String?
  phone        String?
  generation   Int        @default(1)
  parentId     String?
  spouseIds    String[]   @default([])
  imageUrl     String?
  relation     String?
  note         String?
  createdById  String?
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  createdBy    User?      @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([fullName])
  @@index([createdById])
  @@index([familyTreeId])
  @@index([parentId])
}

model Event {
  id           String     @id @default(cuid())
  familyTreeId String
  title        String
  description  String?
  assigneeName String?
  taskStatus   TaskStatus @default(TODO)
  completedAt  DateTime?
  type         EventType  @default(OTHER)
  startsAt     DateTime
  endsAt       DateTime?
  location     String?
  createdById  String?
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  createdBy    User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  comments     EventComment[]
  reactions    EventReaction[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([familyTreeId, startsAt])
  @@index([type])
  @@index([familyTreeId, taskStatus, startsAt])
}

model EventComment {
  id           String    @id @default(cuid())
  familyTreeId String
  eventId      String
  createdById  String?
  content      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy    User?      @relation("EventCommentAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([familyTreeId, eventId, createdAt])
}

model EventReaction {
  id           String       @id @default(cuid())
  familyTreeId String
  eventId      String
  createdById  String
  type         ReactionType
  createdAt    DateTime     @default(now())
  familyTree   FamilyTree   @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("EventReactionAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([eventId, createdById, type])
  @@index([familyTreeId, eventId, createdAt])
}

model NewsPost {
  id              String        @id @default(cuid())
  familyTreeId    String
  title           String
  excerpt         String?
  content         Json
  imageUrl        String?
  category        String        @default("Tin tức")
  readTimeMinutes Int           @default(5)
  featured        Boolean       @default(false)
  publishedAt     DateTime      @default(now())
  authorName      String?
  createdById     String?
  familyTree      FamilyTree    @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("NewsPostAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  comments        NewsComment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([familyTreeId, publishedAt])
  @@index([familyTreeId, featured])
}

model NewsComment {
  id           String    @id @default(cuid())
  familyTreeId String
  newsPostId   String
  content      String
  authorName   String?
  createdById  String?
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  newsPost     NewsPost   @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  createdBy    User?      @relation("NewsCommentAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([familyTreeId, newsPostId, createdAt])
}

model MediaAsset {
  id           String     @id @default(cuid())
  familyTreeId String
  createdById  String?
  name         String
  kind         MediaKind
  category     String
  usedBy       String
  url          String
  sizeMb       Float      @default(0)
  mimeType     String?
  originalName String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  familyTree   FamilyTree @relation(fields: [familyTreeId], references: [id], onDelete: Cascade)
  createdBy    User?      @relation("MediaAssetUploader", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([familyTreeId, createdAt])
  @@index([familyTreeId, kind])
}
